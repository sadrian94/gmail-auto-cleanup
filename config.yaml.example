# Example configuration file for Gmail Auto-Cleanup
# Copy this file to config.yaml and edit with your own credentials

accounts:
  dummy: dev_test_account@gmail.com
  personal: your_email@gmail.com

# Optional: Path to write weekly report markdown files directly into Obsidian
# obsidian_vault_path: "/path/to/your/obsidian/vault"

# Days of age required before moving to Gmail Trash
rules:
  promotions:
    days: 30
    action: TRASH
    enabled: true
  social:
    days: 7
    action: TRASH
    enabled: true
  purchases:
    days: 730  # 2 years
    action: TRASH
    enabled: true
  updates:
    days: 30
    action: TRASH
    enabled: true

# Custom label names for review and exclusion
labels:
  review_to_delete: "Review-to-delete"
  do_not_delete: "Do-not-delete"

# AI Insights Service Settings
# Supports "gemini" and "opencoder-go" providers
ai:
  provider: "gemini"         # "gemini" or "opencoder-go" (or any OpenAI-compatible provider)
  model: "gemini-2.5-flash"  # e.g., "gemini-2.5-flash" or "deepseek-chat"
  api_key_env: "GEMINI_API_KEY" # Name of the env var holding your API key
  # api_key_env: "OPENCODE_API_KEY"  # For opencoder-go / OpenAI-compat providers
  base_url: "https://opencode.ai/zen/go/v1" # Base URL for opencoder-go / OpenAI compatible APIs
  # Tip: store the key in your environment, not here:
  #   Windows: [System.Environment]::SetEnvironmentVariable("GEMINI_API_KEY", "sk-...", "User")
  #   macOS/Linux: export GEMINI_API_KEY=sk-...  (add to ~/.zshrc or ~/.bashrc)

